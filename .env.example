# Environment variables template for Maharashtra Traders Catalog Application
# Copy these keys into your Render or local environment variables setup

# 1. MongoDB Atlas Connection URI
# Leave empty to automatically fallback to secure local JSON storage mode (db_fallback_data.json) if MongoDB is unavailable.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/maharashtra_traders?retryWrites=true&w=majority

# 2. JWT Signature Secret Key
# Strong alphanumeric string used to sign administrator authentication sessions.
JWT_SECRET=some-very-long-and-highly-secure-secret-key-string-here

# 3. Server Node Execution Mode
# Configure as 'production' on deploy systems so fast production assets index.html is served automatically.
NODE_ENV=production
